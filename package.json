{
  "name": "openclaw-chatclaw",
  "version": "0.1.0",
  "description": "OpenClaw ChatClaw channel plugin (WebSocket)",
  "license": "MIT",
  "author": "xbos",
  "type": "module",
  "bin": {
    "chatclaw-account": "./bin/chatclaw-account.js"
  },
  "files": [
    "src/",
    "bin/",
    "!src/**/*.test.ts",
    "!src/**/node_modules/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "npm run typecheck && npm run build",
    "account:create": "node bin/chatclaw-account.js create",
    "account:list": "node bin/chatclaw-account.js list",
    "account:list-agent-limits": "node bin/chatclaw-account.js list-agent-limits",
    "account:set-agent-limits": "node bin/chatclaw-account.js set-agent-limits",
    "account:clear-agent-limits": "node bin/chatclaw-account.js clear-agent-limits",
    "account:delete": "node bin/chatclaw-account.js delete",
    "account:reset-password": "node bin/chatclaw-account.js reset-password"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "axios": "^1.14.0",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.5",
    "openclaw": "2026.3.23",
    "sql.js": "^1.14.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.1.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "openclaw-chatclaw",
      "label": "openclaw-chatclaw",
      "selectionLabel": "openclaw-chatclaw",
      "docsPath": "/channels/openclaw-chatclaw",
      "docsLabel": "openclaw-chatclaw",
      "blurb": "ChatClaw APP channel via WebSocket",
      "order": 80
    },
    "install": {
      "npmSpec": "openclaw-chatclaw",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    }
  }
}
